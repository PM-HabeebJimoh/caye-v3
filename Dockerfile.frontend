# ─────────────────────────────────────────
# CAYE v3.0 — FRONTEND DOCKERFILE
# Node 18 | React 18 | TailwindCSS 3
# ─────────────────────────────────────────

FROM node:18-alpine

# Set working directory
WORKDIR /app

# Copy package files
COPY frontend/package.json frontend/package-lock.json* ./

# Install dependencies
RUN npm install

# Copy application source
COPY frontend/ .

# Expose port
EXPOSE 3000

# Start React development server
CMD ["npm", "start"]